# shellcheck disable=SC2148
mkdir -p "$PWD/.devenv" "$PWD/.direnv"
DEVENV_ROOT_FILE="$PWD/.devenv/root"
printf %s "$PWD" > "$DEVENV_ROOT_FILE"

STATE_FILE="$PWD/.direnv/subflake-locks.state"
TMP_INPUTS_FILE="$PWD/.direnv/subflake-locks.inputs"

{
  echo ".envrc"
  echo "flake.nix"
  echo "flake.lock"
  find flake -mindepth 1 -maxdepth 2 -iname '*.nix' -type f | sort
  find flake -mindepth 2 -maxdepth 2 -iname 'flake.lock' -type f | sort
} > "$TMP_INPUTS_FILE"

# Also make direnv watch them
while IFS= read -r file; do
  watch_file "$file"
done < "$TMP_INPUTS_FILE"

# Compute one combined fingerprint from file contents
NEW_STATE="$(
  while IFS= read -r file; do
    sha256sum "$file"
  done < "$TMP_INPUTS_FILE" | sha256sum | awk '{print $1}'
)"

OLD_STATE=""
[ -f "$STATE_FILE" ] && OLD_STATE="$(cat "$STATE_FILE")"

if [ "$NEW_STATE" != "$OLD_STATE" ]; then
  DIRS=($(find flake -mindepth 1 -maxdepth 1 -type d) ".")
  CURRENT="$PWD"
  for dir in "${DIRS[@]}"; do
    if [ -f "$dir/flake.nix" ]; then
      cd "$dir" || exit 1
      nix flake lock
      cd "$CURRENT" || exit 1
    fi
  done
  printf '%s' "$NEW_STATE" > "$STATE_FILE"
fi

use flake . --accept-flake-config --allow-import-from-derivation --override-input devenv-root "file+file://$DEVENV_ROOT_FILE"
